{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "pnpm run compile",
      "group": "build",
      "problemMatcher": "$tsc",
      "label": "pnpm: compile"
    },
    {
      "type": "shell",
      "command": "pnpm run package",
      "group": "build",
      "label": "pnpm: package"
    },
    {
      "type": "shell",
      "command": "pnpm run watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^(.*?):(\\d+):(\\d+):\\s*(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "esbuild",
          "endsPattern": "Done in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "label": "pnpm: watch"
    },
    {
      "type": "npm",
      "script": "--- WEBVIEW ---",
      "problemMatcher": [],
      "label": "npm: --- WEBVIEW ---",
      "detail": "--- --- --- --- ---"
    }
  ]
}